<Window x:Class="MarketCore.AgentPanel.AgentPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarketCore — Agent Panel"
        Width="900" Height="700"
        MinWidth="700" MinHeight="500"
        Background="#060A12"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="False"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>

        <SolidColorBrush x:Key="AccentGreen"      Color="#00FF88"/>
        <SolidColorBrush x:Key="AccentBlue"       Color="#38BDF8"/>
        <SolidColorBrush x:Key="AccentYellow"     Color="#FBBF24"/>
        <SolidColorBrush x:Key="AccentRed"        Color="#FF4466"/>
        <SolidColorBrush x:Key="AccentPurple"     Color="#A78BFA"/>
        <SolidColorBrush x:Key="AccentOrange"     Color="#FB923C"/>
        <SolidColorBrush x:Key="PanelBg"          Color="#0D1421"/>
        <SolidColorBrush x:Key="PanelBorderColor" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextDim"          Color="#475569"/>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background"      Value="#0D1421"/>
            <Setter Property="BorderBrush"     Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

        <!-- Label de seção — aumentado para 11, branco -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- Label pequeno — aumentado para 11, branco -->
        <Style x:Key="TinyLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#0D1421" BorderBrush="#1E293B" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0">
                    <Canvas Width="24" Height="24">
                        <Line X1="12" Y1="2" X2="12" Y2="5" Stroke="#00FF88" StrokeThickness="1.5"/>
                        <Ellipse Canvas.Left="10.5" Canvas.Top="1" Width="3" Height="3" Fill="#00FF88"/>
                        <Rectangle Canvas.Left="4"  Canvas.Top="5"  Width="16" Height="11" RadiusX="3" RadiusY="3" Fill="#1E2A1E" Stroke="#00FF88" StrokeThickness="1.5"/>
                        <Ellipse Canvas.Left="7"  Canvas.Top="8" Width="3" Height="3" Fill="#00FF88"/>
                        <Ellipse Canvas.Left="14" Canvas.Top="8" Width="3" Height="3" Fill="#00FF88"/>
                        <Rectangle Canvas.Left="8"  Canvas.Top="13" Width="8"  Height="1.5" RadiusX="1" RadiusY="1" Fill="#00FF88"/>
                        <Rectangle Canvas.Left="6"  Canvas.Top="16" Width="12" Height="6"   RadiusX="2" RadiusY="2" Fill="#1E2A1E" Stroke="#00FF88" StrokeThickness="1.5"/>
                        <Rectangle Canvas.Left="2"  Canvas.Top="17" Width="4"  Height="3"   RadiusX="1" RadiusY="1" Fill="#1E2A1E" Stroke="#00FF88" StrokeThickness="1.2"/>
                        <Rectangle Canvas.Left="18" Canvas.Top="17" Width="4"  Height="3"   RadiusX="1" RadiusY="1" Fill="#1E2A1E" Stroke="#00FF88" StrokeThickness="1.2"/>
                    </Canvas>
                </Viewbox>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="MARKETCORE — AGENT PANEL" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00FF88"/>
                    <TextBlock Text="FlowSense Engine v5.0 — WIN / WDO / WSP" FontFamily="Consolas" FontSize="11" Foreground="#FFFFFF"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#00FF88" Margin="0,0,6,0">
                        <Ellipse.Effect><DropShadowEffect Color="#00FF88" BlurRadius="6" ShadowDepth="0"/></Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="StatusLabel" Text="ATIVO" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#00FF88" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="ClockLabel" Grid.Column="3" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- CONTEÚDO 3 COLUNAS -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ COLUNA 1 — SINAL ═══ -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- SINAL ATUAL -->
                    <Border x:Name="SignalBorder" Background="#0D1A0D" BorderBrush="#00FF8844"
                            BorderThickness="1" CornerRadius="6" Padding="12,14" Margin="0,0,0,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="▸ SINAL ATUAL" Foreground="#00FF88" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SignalLabel" Text="▲ COMPRA" FontFamily="Consolas" FontSize="30" FontWeight="Bold"
                                       Foreground="#00FF88" TextAlignment="Center" Margin="0,6,0,6">
                                <TextBlock.Effect><DropShadowEffect Color="#00FF88" BlurRadius="14" ShadowDepth="0"/></TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="PriceLabel" Text="127.854" FontFamily="Consolas" FontSize="24" FontWeight="Bold"
                                       Foreground="#FFFFFF" TextAlignment="Center" Margin="0,0,0,4"/>
                            <!-- WIN FUT — IBOVESPA: fonte maior e cor branca -->
                            <TextBlock Text="WIN FUT — IBOVESPA" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="#FFFFFF" TextAlignment="Center" Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource TinyLabel}" Text="CONFIABILIDADE"/>
                                <TextBlock x:Name="ConfLabel" Grid.Column="1" Text="78%" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00FF88"/>
                            </Grid>
                            <ProgressBar x:Name="ConfBar" Value="78" Maximum="100" Height="6" Margin="0,0,0,10" Background="#0A0F1A" BorderThickness="0">
                                <ProgressBar.Foreground><SolidColorBrush Color="#00FF88"/></ProgressBar.Foreground>
                            </ProgressBar>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource TinyLabel}" Text="FLOW SCORE"/>
                                <TextBlock x:Name="ScoreValueLabel" Grid.Column="1" Text="0.78" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00FF88"/>
                            </Grid>
                            <ProgressBar x:Name="ScoreBar" Value="78" Maximum="100" Height="6" Background="#0A0F1A" BorderThickness="0">
                                <ProgressBar.Foreground><SolidColorBrush Color="#00FF88"/></ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>
                    </Border>

                    <!-- GESTÃO DE RISCO -->
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="▸ GESTÃO DE RISCO" Foreground="#FBBF24"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Background="#0A0F1A" CornerRadius="5" Padding="8,8" Margin="0,0,4,4">
                                    <StackPanel>
                                        <!-- STOP — título branco, maior -->
                                        <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Text="STOP"/>
                                        <TextBlock x:Name="StopLabel"    Text="127.840" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#FF4466"/>
                                        <TextBlock x:Name="StopPtsLabel" Text="-3 pts"  FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" Background="#0A0F1A" CornerRadius="5" Padding="8,8" Margin="4,0,0,4">
                                    <StackPanel>
                                        <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Text="ALVO"/>
                                        <TextBlock x:Name="TargetLabel"    Text="127.884" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00FF88"/>
                                        <TextBlock x:Name="TargetPtsLabel" Text="+6 pts"  FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" Background="#0A0F1A" CornerRadius="5" Padding="8,8" Margin="0,0,4,0">
                                    <StackPanel>
                                        <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Text="R / R"/>
                                        <TextBlock x:Name="RRLabel" Text="1 : 2.0" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#FBBF24"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Text="risco/retorno"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Background="#0A0F1A" CornerRadius="5" Padding="8,8" Margin="4,0,0,0">
                                    <StackPanel>
                                        <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Text="LOTE"/>
                                        <TextBlock x:Name="LoteLabel" Text="2 contratos" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#A78BFA"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Text="tamanho posição"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- CONTEXTO DO SINAL -->
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="▸ CONTEXTO DO SINAL" Foreground="#38BDF8"/>
                            <ItemsControl x:Name="ContextList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                            <TextBlock Text="{Binding Icon}"  FontSize="13" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Texto}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- SAÚDE DO AGENTE -->
                    <Border Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="▸ SAÚDE DO AGENTE" Foreground="#E879F9"/>
                                <TextBlock FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF">
                                    Últ. 20 ops: <Run x:Name="WinRateRun" Foreground="#FBBF24">65%</Run><Run Foreground="#FFFFFF"> acerto</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,3,0,0">
                                    Regime: <Run x:Name="RegimeRun" Foreground="#00FF88">✅ Normal</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,3,0,0">
                                    Próx. evento: <Run x:Name="EventoRun" Foreground="#FB923C">⚠ Copom 16h00</Run>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Ellipse x:Name="HealthDot" Width="10" Height="10" Fill="#00FF88" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <Ellipse.Effect><DropShadowEffect Color="#00FF88" BlurRadius="8" ShadowDepth="0"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="HealthLabel" Text="ATIVO" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#00FF88" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ COLUNA 2 — PLAYERS + PRESSÃO + PADRÕES ═══ -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- PLAYERS ATIVOS -->
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="▸ PLAYERS ATIVOS" Foreground="#FBBF24"/>

                            <!-- COMPRADORES — branco, maior -->
                            <TextBlock Text="COMPRADORES" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="BuyersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF">
                                                    <Run Text="{Binding Nome}"/><Run Text="{Binding Tipo}" Foreground="#FBBF24"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="{Binding VolStr}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#00FF88"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding Pct}" Maximum="100" Height="5" BorderThickness="0" Background="#0A0F1A" Margin="0,2,0,0">
                                                <ProgressBar.Foreground><SolidColorBrush Color="#00FF88"/></ProgressBar.Foreground>
                                            </ProgressBar>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Background="#FFFFFF15" Margin="0,6,0,6"/>

                            <!-- VENDEDORES — branco, maior -->
                            <TextBlock Text="VENDEDORES" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="SellersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF">
                                                    <Run Text="{Binding Nome}"/><Run Text="{Binding Tipo}" Foreground="#FBBF24"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="{Binding VolStr}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FF4466"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding Pct}" Maximum="100" Height="5" BorderThickness="0" Background="#0A0F1A" Margin="0,2,0,0">
                                                <ProgressBar.Foreground><SolidColorBrush Color="#FF4466"/></ProgressBar.Foreground>
                                            </ProgressBar>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Iniciador / Absorvedor — branco, maior -->
                            <TextBlock Text="🔥 Iniciador  ⚡ Absorvedor" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- PRESSÃO DE MERCADO -->
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="▸ PRESSÃO DE MERCADO" Foreground="#38BDF8"/>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <!-- BOOK IMBALANCE — branco -->
                                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" Text="BOOK IMBALANCE"/>
                                <TextBlock x:Name="ImbalanceLabel" Grid.Column="1" Text="68% BID" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#00FF88"/>
                            </Grid>
                            <Grid Height="8" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="BidCol" Width="68*"/>
                                    <ColumnDefinition x:Name="AskCol" Width="32*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#00FF88" CornerRadius="3,0,0,3"/>
                                <Border Grid.Column="1" Background="#FF4466" CornerRadius="0,3,3,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <!-- CVD ACELERAÇÃO — branco -->
                                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" Text="CVD ACELERAÇÃO (5s)"/>
                                <TextBlock x:Name="CVDAccLabel" Grid.Column="1" Text="+14" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#00FF88"/>
                            </Grid>
                            <ProgressBar x:Name="CVDBar" Value="35" Maximum="100" Height="6" BorderThickness="0" Background="#0A0F1A">
                                <ProgressBar.Foreground><SolidColorBrush Color="#00FF88"/></ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>
                    </Border>

                    <!-- PADRÕES HOJE -->
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}" Text="▸ PADRÕES HOJE" Foreground="#A78BFA"/>
                            <ItemsControl x:Name="PatternsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#FFFFFF08" BorderThickness="0,0,0,1" Padding="0,5,0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Hora}"      FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Nome}"      FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Resultado}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="{Binding ResultadoCor}"/>
                                                <!-- Ícone maior e mais visível -->
                                                <TextBlock Grid.Column="3" Text="{Binding Icone}" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock x:Name="PatternStatsLabel" Grid.Column="0" Text="4✅ 1❌" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF"/>
                                <TextBlock x:Name="PatternWRLabel"    Grid.Column="1" Text="80% acerto" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#A78BFA"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ COLUNA 3 — CORRELAÇÕES + LOG ═══ -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- CORRELAÇÕES -->
                <Border Grid.Row="0" Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="▸ CORRELAÇÃO EM TEMPO REAL" Foreground="#A78BFA"/>
                        <ItemsControl x:Name="CorrelList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#FFFFFF08" BorderThickness="0,0,0,1" Padding="0,6,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Ativo}"  FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{Binding Cor}"    VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Valor}"  FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF"          VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding PctStr}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{Binding PctCor}" VerticalAlignment="Center"/>
                                            <!-- Extra — branco em vez de cinza escuro -->
                                            <TextBlock Grid.Column="3" Text="{Binding Extra}"  FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"          VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Margin="0,8,0,0">
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <!-- WIN/WDO — branco -->
                                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" Text="WIN / WDO"/>
                                <TextBlock x:Name="CorrWinWdoLabel" Grid.Column="1" Text="-0.79" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FF4466"/>
                            </Grid>
                            <ProgressBar x:Name="CorrWinWdoBar" Value="79" Maximum="100" Height="5" BorderThickness="0" Background="#0A0F1A" Margin="0,0,0,8">
                                <ProgressBar.Foreground><SolidColorBrush Color="#FF4466"/></ProgressBar.Foreground>
                            </ProgressBar>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <!-- WIN/WSP — branco -->
                                <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF" Text="WIN / WSP"/>
                                <TextBlock x:Name="CorrWinWspLabel" Grid.Column="1" Text="+0.67" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#38BDF8"/>
                            </Grid>
                            <ProgressBar x:Name="CorrWinWspBar" Value="67" Maximum="100" Height="5" BorderThickness="0" Background="#0A0F1A">
                                <ProgressBar.Foreground><SolidColorBrush Color="#38BDF8"/></ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>

                        <Border Background="#00FF8808" BorderBrush="#00FF8820" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock x:Name="CorrStatusLabel" Text="✅ Regime: Correlação normal" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#00FF88"/>
                                <TextBlock x:Name="CorrGapLabel"    Text="WIN tem espaço de +0.23% para igualar WSP" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- LOG DE EVENTOS -->
                <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SectionLabel}" Text="▸ LOG DE EVENTOS" Foreground="#00FF88" Margin="0,0,0,8"/>
                        <ScrollViewer Grid.Row="1" x:Name="LogScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="LogList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="{Binding TagCor}" RadiusX="2" RadiusY="2"/>
                                            <Border Grid.Column="1" Background="{Binding TagBg}" CornerRadius="0,4,4,0" Padding="10,8">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="{Binding Hora}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,10,0"/>
                                                        <Border Background="{Binding TagBg}" BorderBrush="{Binding TagCor}" BorderThickness="1" CornerRadius="2" Padding="5,2">
                                                            <TextBlock Text="{Binding Tag}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="{Binding TagCor}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Mensagem}" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" TextWrapping="Wrap" LineHeight="18"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>
