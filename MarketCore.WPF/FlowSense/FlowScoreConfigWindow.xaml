<Window x:Class="MarketCore.FlowSense.FlowScoreConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibrar FlowScore"
        Width="560" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0D0D0D"
        Foreground="White"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00BFFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="ParamLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="210"/>
        </Style>
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="#0D0D0D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33CFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,16">
        <StackPanel>

            <TextBlock Text="&#9881;  Calibrar FlowScore Engine"
                       FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
            <TextBlock Text="Ajuste os pesos e parâmetros de cada componente. Clique em Aplicar para confirmar."
                       Foreground="#777" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <Separator/>

            <!-- ── PESOS DOS COMPONENTES ─────────────────────────────── -->
            <TextBlock Text="PESOS DOS COMPONENTES  (serão normalizados para 100%)"
                       Style="{StaticResource SectionHeader}"/>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="BrokerFlow" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderWeightBroker" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.01"/>
                <TextBlock x:Name="LabelWeightBroker" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Fluxo Direto" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderWeightFluxo" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.01"/>
                <TextBlock x:Name="LabelWeightFluxo" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Book" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderWeightBook" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.01"/>
                <TextBlock x:Name="LabelWeightBook" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Detectores" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderWeightDetect" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.01"/>
                <TextBlock x:Name="LabelWeightDetect" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <TextBlock x:Name="WeightSumLabel" Foreground="#888" FontSize="11" Margin="0,4,0,0" TextAlignment="Right"/>
            <Separator/>

            <!-- ── BROKERFLOW ────────────────────────────────────────── -->
            <TextBlock Text="BROKERFLOW" Style="{StaticResource SectionHeader}"/>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="RVOL — Multiplicador máx." Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderRvolMax" Grid.Column="1" Minimum="1" Maximum="4" SmallChange="0.1"/>
                <TextBlock x:Name="LabelRvolMax" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Fase Abertura — multiplicador" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderPhaseAbertura" Grid.Column="1" Minimum="0.5" Maximum="3" SmallChange="0.05"/>
                <TextBlock x:Name="LabelPhaseAbertura" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Fase Leilão — multiplicador" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderPhaseLeilao" Grid.Column="1" Minimum="0.5" Maximum="3" SmallChange="0.05"/>
                <TextBlock x:Name="LabelPhaseLeilao" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Fase Meio — multiplicador" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderPhaseMeio" Grid.Column="1" Minimum="0.5" Maximum="3" SmallChange="0.05"/>
                <TextBlock x:Name="LabelPhaseMeio" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Separator/>

            <!-- ── FLUXO DIRETO ──────────────────────────────────────── -->
            <TextBlock Text="FLUXO DIRETO" Style="{StaticResource SectionHeader}"/>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Peso Delta (1min/3min)" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderFluxoDelta" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05"/>
                <TextBlock x:Name="LabelFluxoDelta" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Peso CVD Divergence" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderFluxoCVD" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05"/>
                <TextBlock x:Name="LabelFluxoCVD" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Separator/>

            <!-- ── BOOK ──────────────────────────────────────────────── -->
            <TextBlock Text="BOOK" Style="{StaticResource SectionHeader}"/>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Peso Pressão Bid/Ask" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderBookPressure" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05"/>
                <TextBlock x:Name="LabelBookPressure" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Peso Desequilíbrio (níveis)" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderBookImbalance" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05"/>
                <TextBlock x:Name="LabelBookImbalance" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Peso Renewable" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderBookRenewable" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05"/>
                <TextBlock x:Name="LabelBookRenewable" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Peso Distância VWAP" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderBookVWAP" Grid.Column="1" Minimum="0" Maximum="1" SmallChange="0.05"/>
                <TextBlock x:Name="LabelBookVWAP" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Score Renewable ativo" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderBookRenewableScore" Grid.Column="1" Minimum="0" Maximum="100" SmallChange="5"/>
                <TextBlock x:Name="LabelBookRenewableScore" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Separator/>

            <!-- ── DETECTORES ────────────────────────────────────────── -->
            <TextBlock Text="DETECTORES" Style="{StaticResource SectionHeader}"/>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Penalidade Spoof" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderSpoofPenalty" Grid.Column="1" Minimum="0" Maximum="100" SmallChange="5"/>
                <TextBlock x:Name="LabelSpoofPenalty" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Bônus Iceberg" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderIcebergBonus" Grid.Column="1" Minimum="0" Maximum="100" SmallChange="5"/>
                <TextBlock x:Name="LabelIcebergBonus" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Penalidade Exaustão Renko" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderExhaustionPenalty" Grid.Column="1" Minimum="0" Maximum="100" SmallChange="5"/>
                <TextBlock x:Name="LabelExhaustionPenalty" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Penalidade Stop Hunt" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderStopHuntPenalty" Grid.Column="1" Minimum="0" Maximum="100" SmallChange="5"/>
                <TextBlock x:Name="LabelStopHuntPenalty" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Limiar CVD Divergence" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderCVDThreshold" Grid.Column="1" Minimum="10" Maximum="100" SmallChange="5"/>
                <TextBlock x:Name="LabelCVDThreshold" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>
            <Grid Margin="0,3,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                <TextBlock Text="Score CVD (bônus/penalidade)" Style="{StaticResource ParamLabel}" Grid.Column="0"/>
                <Slider x:Name="SliderCVDScore" Grid.Column="1" Minimum="0" Maximum="100" SmallChange="5"/>
                <TextBlock x:Name="LabelCVDScore" Style="{StaticResource ValueLabel}" Grid.Column="2"/>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 AUTO-CALIBRADOR
                 ══════════════════════════════════════════════════════════ -->
            <Separator Margin="0,16,0,0"/>
            <Border Margin="0,12,0,0" Background="#0A1A0A" BorderBrush="#00C853"
                    BorderThickness="1" CornerRadius="4" Padding="12,10">
                <StackPanel>

                    <!-- Título -->
                    <TextBlock Text="&#9889;  Auto-Calibração com Dados Históricos"
                               FontSize="12" FontWeight="Bold" Foreground="#00C853" Margin="0,0,0,4"/>
                    <TextBlock Text="Analisa correlação entre os componentes e o movimento real do preço."
                               FontSize="10" Foreground="#888888" Margin="0,0,0,10"/>

                    <!-- Seletores -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Período:" FontSize="11"
                                   Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1" x:Name="ComboPeriodo"
                                  Background="#1A1A1A" Foreground="#E8E8E8"
                                  BorderBrush="#3A3A3A" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Column="3" Text="Mov. mín.:" FontSize="11"
                                   Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="4" x:Name="ComboMovMin"
                                  Background="#1A1A1A" Foreground="#E8E8E8"
                                  BorderBrush="#3A3A3A" FontFamily="Consolas" FontSize="11"/>
                    </Grid>

                    <!-- Botão iniciar -->
                    <Button x:Name="BtnAutoCalibrar"
                            Content="&#9889;  Iniciar Auto-Calibração"
                            Margin="0,0,0,10" Padding="14,7"
                            Background="#003A10" BorderBrush="#00C853" Foreground="#00C853"
                            FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#005A18"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Painel de progresso -->
                    <StackPanel x:Name="PainelProgresso" Visibility="Collapsed" Margin="0,0,0,10">
                        <ProgressBar x:Name="ProgressoCalib"
                                     Minimum="0" Maximum="100" Value="0"
                                     Height="12" Margin="0,0,0,4"
                                     Foreground="#00C853" Background="#1A1A1A"/>
                        <TextBlock x:Name="LabelStatusCalib"
                                   Text="Analisando..." FontSize="10"
                                   Foreground="#AAAAAA" FontFamily="Consolas"/>
                    </StackPanel>

                    <!-- Painel de resultado -->
                    <Border x:Name="PainelResultado" Visibility="Collapsed"
                            Background="#0D0D0D" BorderBrush="#2A2A2A"
                            BorderThickness="1" CornerRadius="3" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="RESULTADO DA CALIBRAÇÃO"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#AAAAAA" FontFamily="Consolas" Margin="0,0,0,6"/>

                            <!-- Cabeçalho -->
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Componente" FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" Text="Acerto"     FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="2" Text="Ratio"      FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="3" Text="Atual"      FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="4" Text="Sugerido"   FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="5" Text=""           FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,2,0,4"/>

                            <!-- BrokerFlow -->
                            <Grid Margin="0,1,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="BrokerFlow"  FontSize="10" Foreground="#CCCCCC" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" x:Name="TxtResultBrokerAcerto" FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="2" x:Name="TxtResultBrokerRatio"  FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="3" x:Name="TxtResultBrokerAtual"  FontSize="10" Foreground="#888888" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="4" x:Name="TxtResultBrokerSug"    FontSize="10" Foreground="#00C853" FontFamily="Consolas" FontWeight="Bold"/>
                                <TextBlock Grid.Column="5" x:Name="TxtResultBrokerTend"   FontSize="12" Foreground="#00C853" FontFamily="Consolas"/>
                            </Grid>

                            <!-- FluxoDireto -->
                            <Grid Margin="0,1,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Fluxo Direto" FontSize="10" Foreground="#CCCCCC" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" x:Name="TxtResultFluxoAcerto" FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="2" x:Name="TxtResultFluxoRatio"  FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="3" x:Name="TxtResultFluxoAtual"  FontSize="10" Foreground="#888888" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="4" x:Name="TxtResultFluxoSug"    FontSize="10" Foreground="#00C853" FontFamily="Consolas" FontWeight="Bold"/>
                                <TextBlock Grid.Column="5" x:Name="TxtResultFluxoTend"   FontSize="12" Foreground="#00C853" FontFamily="Consolas"/>
                            </Grid>

                            <!-- Book -->
                            <Grid Margin="0,1,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Book"        FontSize="10" Foreground="#CCCCCC" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" x:Name="TxtResultBookAcerto" FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="2" x:Name="TxtResultBookRatio"  FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="3" x:Name="TxtResultBookAtual"  FontSize="10" Foreground="#888888" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="4" x:Name="TxtResultBookSug"    FontSize="10" Foreground="#00C853" FontFamily="Consolas" FontWeight="Bold"/>
                                <TextBlock Grid.Column="5" x:Name="TxtResultBookTend"   FontSize="12" Foreground="#00C853" FontFamily="Consolas"/>
                            </Grid>

                            <!-- Detectores -->
                            <Grid Margin="0,1,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Detectores"  FontSize="10" Foreground="#CCCCCC" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" x:Name="TxtResultDetectAcerto" FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="2" x:Name="TxtResultDetectRatio"  FontSize="10" Foreground="#AAAAAA" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="3" x:Name="TxtResultDetectAtual"  FontSize="10" Foreground="#888888" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="4" x:Name="TxtResultDetectSug"    FontSize="10" Foreground="#00C853" FontFamily="Consolas" FontWeight="Bold"/>
                                <TextBlock Grid.Column="5" x:Name="TxtResultDetectTend"   FontSize="12" Foreground="#00C853" FontFamily="Consolas"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,2,0,4"/>
                            <TextBlock x:Name="TxtResultJanelas"
                                       FontSize="9" Foreground="#666666"
                                       FontFamily="Consolas" TextWrapping="Wrap"/>
                            <TextBlock Text="&#8593; Sliders atualizados — clique Aplicar para confirmar"
                                       FontSize="9" Foreground="#00C853"
                                       Margin="0,4,0,0" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ── BOTÕES ─────────────────────────────────────────────── -->
            <Separator Margin="0,16,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="BtnReset"  Content="Restaurar padrões" Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"/>
                <Button x:Name="BtnCancel" Content="Cancelar"          Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"/>
                <Button x:Name="BtnApply"  Content="&#10004;  Aplicar" Style="{StaticResource BtnPrimary}"/>
            </StackPanel>

