<Window x:Class="MarketCore.FlowSense.ProfitLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarketCore — Conexão Profit"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D"
        Foreground="White"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#00BFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00BFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#151515"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00BFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#151515"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="#0D0D0D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33CFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de modo (Real / Simulador) — toggle style -->
        <Style x:Key="BtnModeActive" TargetType="Button">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="#0D0D0D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnModeInactive" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <StackPanel Margin="32,28,32,28">

        <!-- TÍTULO -->
        <TextBlock Text="MarketCore FlowSense"
                   FontSize="20" FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Selecione o modo de conexão"
                   FontSize="11" Foreground="#666"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- SELEÇÃO DE MODO -->
        <TextBlock Text="MODO DE OPERAÇÃO"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#00BFFF"
                   Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Botão Mercado Real -->
            <Button x:Name="BtnModeReal" Grid.Column="0"
                    Style="{StaticResource BtnModeActive}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="📈" FontSize="18" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                    <TextBlock Text="Mercado Real" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="ProfitDLL" FontSize="10" HorizontalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Button>

            <!-- Botão Simulador -->
            <Button x:Name="BtnModeSimulator" Grid.Column="2"
                    Style="{StaticResource BtnModeInactive}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="🧪" FontSize="18" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                    <TextBlock Text="Simulador" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="SimulatorProvider" FontSize="10" HorizontalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- PAINEL DE CREDENCIAIS (visível só no modo Real) -->
        <StackPanel x:Name="PanelCredentials">

            <TextBlock Text="CREDENCIAIS PROFIT — DATA SOLUTION"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#00BFFF"
                       Margin="0,0,0,10"/>

            <!-- CHAVE DE ATIVAÇÃO -->
            <TextBlock Text="Chave de Ativação" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtActivationKey"
                     Style="{StaticResource DarkTextBox}"
                     MaxLength="100"
                     Margin="0,0,0,14"/>

            <!-- USUÁRIO -->
            <TextBlock Text="Usuário (login Nelogica)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtUsername"
                     Style="{StaticResource DarkTextBox}"
                     MaxLength="100"
                     Margin="0,0,0,14"/>

            <!-- SENHA -->
            <TextBlock Text="Senha" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,16">
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource DarkPasswordBox}"/>
                <Button x:Name="BtnTogglePassword"
                        Content="👁" Width="32" Height="32"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#666" FontSize="14" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBox x:Name="TxtPasswordVisible"
                         Style="{StaticResource DarkTextBox}"
                         Visibility="Collapsed" MaxLength="100"/>
            </Grid>

            <!-- LEMBRAR -->
            <CheckBox x:Name="ChkRemember"
                      Content="Lembrar credenciais neste computador"
                      Margin="0,0,0,20"/>

        </StackPanel>

        <!-- AVISO SIMULADOR (visível só no modo Simulador) -->
        <Border x:Name="PanelSimulatorInfo"
                Visibility="Collapsed"
                Background="#0D1A0D"
                BorderBrush="#1A4A1A"
                BorderThickness="1"
                CornerRadius="3"
                Padding="14,12"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="🧪  Modo Simulador ativo"
                           Foreground="#4CAF50" FontWeight="Bold" FontSize="13"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Os dados serão gerados pelo SimulatorProvider interno. Nenhuma credencial é necessária."
                           Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- MENSAGEM DE ERRO -->
        <Border x:Name="ErrorBorder"
                Background="#2A0A0A" BorderBrush="#8B0000"
                BorderThickness="1" CornerRadius="3"
                Padding="12,8" Margin="0,0,0,14"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorLabel" Foreground="#FF6666" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- BOTÕES CANCELAR / CONECTAR -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnCancel" Grid.Column="0"
                    Content="Cancelar" Style="{StaticResource BtnSecondary}"/>
            <Button x:Name="BtnConnect" Grid.Column="2"
                    Content="🔗  Conectar" Style="{StaticResource BtnPrimary}"/>
        </Grid>

        <!-- RODAPÉ -->
        <TextBlock Text="As credenciais são salvas de forma criptografada apenas neste computador."
                   Foreground="#444" FontSize="10"
                   TextWrapping="Wrap" TextAlignment="Center"
                   Margin="0,14,0,0"/>

    </StackPanel>
</Window>
