<Window x:Class="MarketCore.WPF.RecordingConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração de Gravação"
        Width="520" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0D0D"
        Foreground="#E8E8E8"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="📁  Caminho de Gravação dos Históricos"
                       FontSize="14" FontWeight="Bold" Foreground="#00C853"/>
            <TextBlock Text="Escolha onde os arquivos de trades e book serão armazenados."
                       FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Campo de caminho -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="TxPath"
                         Background="Transparent"
                         Foreground="#E8E8E8"
                         BorderThickness="0"
                         Padding="8,6"
                         FontFamily="Consolas"
                         FontSize="11"
                         VerticalContentAlignment="Center"
                         CaretBrush="#00C853"/>
            </Border>
            <Button Grid.Column="2" x:Name="BtnBrowse"
                    Content="Procurar..."
                    Style="{StaticResource DarkButton}"
                    Click="BtnBrowse_Click"/>
        </Grid>

        <!-- Info de espaço disponível -->
        <Border Grid.Row="4" Background="#111111" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="4" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ESPAÇO LIVRE" FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                    <TextBlock x:Name="TbFreeSpace" Text="--" FontSize="12" Foreground="#00C853" FontFamily="Consolas" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="JÁ GRAVADO" FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                    <TextBlock x:Name="TbUsedSpace" Text="--" FontSize="12" Foreground="#FFD600" FontFamily="Consolas" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="ESTIMATIVA (1 ANO)" FontSize="9" Foreground="#666666" FontFamily="Consolas"/>
                    <TextBlock Text="~10 GB" FontSize="12" Foreground="#AAAAAA" FontFamily="Consolas" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Aviso HD externo -->
        <Border Grid.Row="6" Background="#1A1200" BorderBrush="#3A2A00" BorderThickness="1" CornerRadius="4" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠ " Foreground="#FFD600" FontSize="11"/>
                <TextBlock TextWrapping="Wrap" Foreground="#CCAA00" FontSize="10">
                    <Run Text="Se usar HD externo, certifique-se que está conectado antes de iniciar o programa."/>
                    <Run Text=" O sistema usa o caminho padrão se o drive não for encontrado."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Botões -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="BtnDefault"
                    Content="Usar Padrão"
                    Style="{StaticResource DarkButton}"
                    Click="BtnDefault_Click"
                    Foreground="#888888"/>

            <Button Grid.Column="2" x:Name="BtnCancel"
                    Content="Cancelar"
                    Style="{StaticResource DarkButton}"
                    Click="BtnCancel_Click"/>

            <Button Grid.Column="4" x:Name="BtnSave"
                    Content="✔  Salvar"
                    Style="{StaticResource DarkButton}"
                    Click="BtnSave_Click"
                    Background="#003A10" BorderBrush="#00C853" Foreground="#00C853"/>
        </Grid>
    </Grid>
</Window>
